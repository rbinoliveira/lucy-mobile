{
  "name": "lucy-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "prebuild:android": "npx expo prebuild --clean && npx expo run:android",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:android:dev": "npx eas-cli build --platform android --profile development",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:android:staging": "npx eas-cli build --platform android --profile staging",
    "build:android:production": "npx eas-cli build --platform android --profile production",
    "build:ios:dev": "npx eas-cli build --platform ios --profile development",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "build:ios:staging": "npx eas-cli build --platform ios --profile staging",
    "build:ios:production": "npx eas-cli build --platform ios --profile production",
    "submit:ios:staging": "npx eas-cli submit --platform ios --latest",
    "submit:ios:production": "npx eas-cli submit --platform ios --latest"
  },
  "dependencies": {
    "@expo-google-fonts/averia-serif-libre": "^0.4.1",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.90.12",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-apple-authentication": "^8.0.8",
    "expo-auth-session": "^7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.10.0",
    "lucide-react-native": "^0.576.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.69.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@rbinflow/eslint-config": "^1.0.10",
    "@types/detox": "^18.1.3",
    "@types/react": "~19.1.0",
    "detox": "^20.47.0",
    "nativewind": "^4.2.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
