# Backend API URL (without /api suffix)
# 
# For development, use one of the following:
# - iOS Simulator: http://localhost:3333
# - Android Emulator: http://10.0.2.2:3333 (special IP for Android emulator)
# - Physical device: http://YOUR_LOCAL_IP:3333
#
# To find your local IP:
# - Mac/Linux: ifconfig | grep "inet " | grep -v 127.0.0.1
# - Windows: ipconfig | findstr IPv4
#
EXPO_PUBLIC_API_URL=http://localhost:3333
EXPO_PUBLIC_APP_NAME=adere

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Google OAuth Client ID (from Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
# Required for Google Sign-In. Use the Web client ID for Expo managed workflow.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
