{
  "expo": {
    "name": "Lucy",
    "slug": "lucy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/application/assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rubinhodev.lucy",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/application/assets/images/adaptive-icon.png",
        "backgroundColor": "#008b84"
      },
      "package": "com.rubinhodev.lucy",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/application/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/application/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
			"@react-native-firebase/app",
			"@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "719d96da-b37d-413c-b145-9d6a544f1193"
      }
    }
  }
}
