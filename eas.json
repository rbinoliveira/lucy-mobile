{
  "cli": {
    "version": ">= 16.3.1",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "android": {
        "distribution": "internal",
        "buildType": "apk"
      },
      "ios": {
        "distribution": "internal",
        "resourceClass": "m-medium"
      },
      "env": {
        "ANDROID_HOME": "/Users/rubinho/Library/Android/sdk",
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_APP_NAME": "adere"
      }
    },
    "preview": {
      "android": {
        "distribution": "internal",
        "buildType": "apk"
      },
      "ios": {
        "distribution": "internal",
        "simulator": true
      },
      "env": {
        "ANDROID_HOME": "/Users/rubinho/Library/Android/sdk",
        "EXPO_PUBLIC_APP_ENV": "preview",
        "EXPO_PUBLIC_APP_NAME": "adere"
      }
    },
    "staging": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "distribution": "store",
        "autoIncrement": true
      },
      "env": {
        "ANDROID_HOME": "/Users/rubinho/Library/Android/sdk",
        "EXPO_PUBLIC_APP_ENV": "staging",
        "EXPO_PUBLIC_APP_NAME": "adere"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "distribution": "store"
      },
      "env": {
        "ANDROID_HOME": "/Users/rubinho/Library/Android/sdk",
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_APP_NAME": "adere"
      }
    }
  }
}
